#:include textinputlinenumber.kv

<ExampleRoot@BoxLayout>:

    # lines_show: lines_show
    # cursor_col_show: cursor_col_show
    # cursor_row_show: cursor_row_show
    lni:lni

    orientation: 'vertical'

    Button:
        text: "Tab"
        size_hint_y: .05
        on_release: root.tab()

    TextInputLineNumber:
        id: lni

    BoxLayout:
        size_hint_y: .1
        # orientation: 'horizontal'
        # Label:
        #     text: 'Lines:'
        # Label:
        #     id: lines_show
        #     text: str(lni.amount_lines)
        # Label:
        #     text: 'Cursor Column:'
        # Label:
        #     id: cursor_col_show
        #     text: str(lni.cursor[0])
        # Label:
        #     text: 'Cursor Row:'
        # Label:
        #     id: cursor_row_show
        #     text: str(lni.cursor[1])
        # Label:
        #     text: 'Scroll Y:'
        # Label:
        #     id: cursor_row_show
        #     text: str(round(lni.scroll_y, 2))
        Button:
            text: "Delete"
            on_release: root.append_lorem_ipsum()
            # size_hint_x: 3

        Button:
            text: "Save"
            on_press: root.save()
            on_release: root.lni.text_content.focus=True
